# Required
OPENAI_API_KEY=

# Model - gpt-4o-mini is cheap and sufficient; upgrade if needed
OPENAI_MODEL=gpt-4o-mini

# LangSmith tracing - optional observability for LangChain/LangGraph runs.
# Leave commented for local runs without LangSmith.
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=langgraph-governed-agent
# If your LangSmith account is not in the default US region, set the regional API endpoint.
# EU example: LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
# If your API key is linked to multiple workspaces, set the workspace ID.
# LANGSMITH_WORKSPACE_ID=
# Optional: write Chainlit answers into an existing LangSmith dataset so
# feedback can be mirrored into the dataset example metadata. Set one.
# LANGSMITH_FEEDBACK_DATASET_NAME=
# LANGSMITH_FEEDBACK_DATASET_ID=

# GA4 MCP server - leave blank to run in SQLite-only mode
#
# HTTP MCP server:
GA_MCP_URL=
GA_MCP_AUTH=
GA_MCP_TRANSPORT=streamable_http
#
# Local stdio MCP server, for this repo's OAuth-based GA4 MCP server:
# GA_MCP_TRANSPORT=stdio
# GA_MCP_COMMAND=python
# GA_MCP_ARGS=-m ga4_mcp_server
#
# Google OAuth Desktop client and GA4 defaults for the local MCP server:
# GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
# GOOGLE_PROJECT_ID=your-google-cloud-project-id
# GA4_PROPERTY_ID=123456789
# Optional local OAuth token path override. Keep this out of git.
# GA4_TOKEN_PATH=
# OAuth callback defaults. If using a Web OAuth client, add this exact
# redirect URI in Google Cloud: http://127.0.0.1:8080/
# GA4_OAUTH_HOST=127.0.0.1
# GA4_OAUTH_PORT=8080

# Chainlit session signing key - required for the sidebar data layer (any random string)
CHAINLIT_AUTH_SECRET=

# Governance circuit breaker defaults
# Maximum cumulative EUR cost per persisted agent session before the graph halts.
AGENT_MAX_COST_EUR=0.05
# Maximum LangGraph steps per invocation before LangGraph stops runaway loops.
AGENT_RECURSION_LIMIT=12

# Orchestration metrics
# Model context window in tokens, used to compute context_window_pct on each
# call_model run. Must match OPENAI_MODEL (default 128000 fits gpt-4o-mini).
# AGENT_MODEL_CONTEXT_WINDOW=128000
