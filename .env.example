# Required
OPENAI_API_KEY=

# Model - gpt-4o-mini is cheap and sufficient; upgrade if needed
OPENAI_MODEL=gpt-4o-mini

# GA4 MCP server - leave blank to run in SQLite-only mode
#
# HTTP MCP server:
GA_MCP_URL=
GA_MCP_AUTH=
GA_MCP_TRANSPORT=streamable_http
#
# Local stdio MCP server, for this repo's OAuth-based GA4 MCP server:
# GA_MCP_TRANSPORT=stdio
# GA_MCP_COMMAND=python
# GA_MCP_ARGS=-m ga4_mcp_server
#
# Google OAuth Desktop client and GA4 defaults for the local MCP server:
# GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
# GOOGLE_PROJECT_ID=your-google-cloud-project-id
# GA4_PROPERTY_ID=123456789
# Optional local OAuth token path override. Keep this out of git.
# GA4_TOKEN_PATH=
# OAuth callback defaults. If using a Web OAuth client, add this exact
# redirect URI in Google Cloud: http://127.0.0.1:8080/
# GA4_OAUTH_HOST=127.0.0.1
# GA4_OAUTH_PORT=8080

# Chainlit session signing key - required for the sidebar data layer (any random string)
CHAINLIT_AUTH_SECRET=

# Governance circuit breaker defaults
# Maximum cumulative EUR cost per persisted agent session before the graph halts.
AGENT_MAX_COST_EUR=0.05
# Maximum LangGraph steps per invocation before LangGraph stops runaway loops.
AGENT_RECURSION_LIMIT=12
